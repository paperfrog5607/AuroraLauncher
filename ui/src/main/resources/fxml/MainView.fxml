<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            styleClass="main-window"
            fx:controller="org.aurora.launcher.ui.controller.MainViewController">

    <!-- === 顶部状态栏 === -->
    <top>
        <HBox fx:id="topBar" styleClass="top-bar" prefHeight="40" alignment="CENTER_RIGHT">
            <HBox.margin><Insets left="16" right="16"/></HBox.margin>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <Label fx:id="timeLabel" text="22:30" styleClass="time-display"/>
            
            <StackPane>
                <Button fx:id="notificationBtn" styleClass="notification-btn" onAction="#onNotificationClick">
                    <graphic><Label text="🔔" styleClass="notification-icon"/></graphic>
                </Button>
                <Label fx:id="notificationBadge" text="3" styleClass="notification-badge" visible="false"
                       StackPane.alignment="TOP_RIGHT">
                    <StackPane.margin><Insets top="-4" right="-4"/></StackPane.margin>
                </Label>
            </StackPane>
            
            <StackPane styleClass="user-avatar">
                <Label text="👤" styleClass="avatar-icon"/>
            </StackPane>
        </HBox>
    </top>

    <!-- === 主内容区域 === -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <ScrollPane fitToWidth="true" styleClass="home-scroll">
                <VBox fx:id="homeContent" styleClass="home-content" spacing="24">
                    
                    <!-- === 平台切换标签 === -->
                    <HBox styleClass="platform-tabs">
                        <Button fx:id="tabMinecraft" text="Minecraft" styleClass="platform-tab,active" onAction="#onPlatformMinecraft"/>
                        <Button fx:id="tabSteam" text="Steam" styleClass="platform-tab" onAction="#onPlatformSteam"/>
                    </HBox>
                    
                    <!-- === 快速启动区域 === -->
                    <VBox fx:id="quickLaunchSection" styleClass="quick-launch-section">
                        <Label text="快速启动" styleClass="quick-launch-header"/>
                        <HBox styleClass="quick-launch-row" alignment="CENTER_LEFT">
                            <Label text="🎮" style="-fx-font-size: 24px;"/>
                            <VBox styleClass="quick-launch-info">
                                <Label fx:id="quickLaunchGame" text="Minecraft 1.21.4" styleClass="quick-launch-game"/>
                                <Label fx:id="quickLaunchMeta" text="Fabric · 最后启动: 今天" styleClass="quick-launch-meta"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="▶ 启动" styleClass="quick-launch-btn" onAction="#onQuickLaunch"/>
                            <Button text="切换版本 ▼" styleClass="quick-launch-version" onAction="#onVersionSelect"/>
                        </HBox>
                    </VBox>
                    
                    <!-- === 游戏网格 === -->
                    <VBox styleClass="games-section">
                        <Label fx:id="gamesTitle" text="我的游戏" styleClass="section-header"/>
                        <HBox fx:id="gameGrid" styleClass="games-grid" spacing="12" alignment="CENTER_LEFT"/>
                    </VBox>
                    
                </VBox>
            </ScrollPane>
            
            <!-- 通知面板 -->
            <VBox fx:id="notificationCenter" styleClass="notification-panel" visible="false"
                  managed="false" alignment="TOP_CENTER" spacing="12">
                <StackPane.margin><Insets top="60"/></StackPane.margin>
            </VBox>
        </StackPane>
    </center>

    <!-- === 底部导航 Dock === -->
    <bottom>
        <HBox styleClass="bottom-dock" alignment="CENTER" prefHeight="60">
            <Button fx:id="navLaunch" styleClass="dock-item,active" onAction="#onLaunchTab">
                <graphic><Label text="🏠" styleClass="dock-icon"/></graphic>
                <text>主页</text>
            </Button>
            <Button fx:id="navDownload" styleClass="dock-item" onAction="#onDownloadTab">
                <graphic><Label text="⬇" styleClass="dock-icon"/></graphic>
                <text>下载</text>
            </Button>
            <Button fx:id="navCreator" styleClass="dock-item" onAction="#onCreatorTab">
                <graphic><Label text="🎨" styleClass="dock-icon"/></graphic>
                <text>创作</text>
            </Button>
            <Button fx:id="navNetwork" styleClass="dock-item" onAction="#onNetworkTab">
                <graphic><Label text="🌐" styleClass="dock-icon"/></graphic>
                <text>联机</text>
            </Button>
            <Button fx:id="navSettings" styleClass="dock-item" onAction="#onSettingsTab">
                <graphic><Label text="⚙" styleClass="dock-icon"/></graphic>
                <text>设置</text>
            </Button>
        </HBox>
    </bottom>

</BorderPane>