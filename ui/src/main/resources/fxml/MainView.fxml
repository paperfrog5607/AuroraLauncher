<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            styleClass="main-window"
            fx:controller="org.aurora.launcher.ui.controller.MainViewController">

    <top>
        <VBox>
            <!-- 玻璃顶栏 -->
            <HBox fx:id="topBar" styleClass="glass-nav" prefHeight="48">
                <!-- Logo -->
                <HBox styleClass="nav-logo" alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitWidth="28" fitHeight="28">
                        <image>
                            <Image url="@../images/logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="Aurora" styleClass="app-title" visible="false"/>
                </HBox>
                
                <!-- 导航标签 -->
                <HBox fx:id="tabBar" styleClass="nav-bar" spacing="4" alignment="CENTER">
                    <Button fx:id="navLaunch" text="启动" onAction="#onLaunchTab"
                            styleClass="nav-btn"/>
                    <Button fx:id="navDownload" text="下载" onAction="#onDownloadTab"
                            styleClass="nav-btn"/>
                    <Button fx:id="navCreator" text="创作" onAction="#onCreatorTab"
                            styleClass="nav-btn"/>
                    <Button fx:id="navSettings" text="更多" onAction="#onSettingsTab"
                            styleClass="nav-btn"/>
                </HBox>
                
                <!-- 空白填充 -->
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- 窗口控制 -->
                <HBox styleClass="window-controls" alignment="CENTER" spacing="12">
                    <Button onAction="#onMinimize" styleClass="btn-icon,btn-ghost" text="─"/>
                    <Button onAction="#onClose" styleClass="btn-icon,btn-ghost" text="✕"/>
                </HBox>
                
                <HBox.margin>
                    <Insets top="0" right="16" bottom="0" left="16"/>
                </HBox.margin>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
