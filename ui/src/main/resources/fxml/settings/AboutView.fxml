<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" styleClass="page-content"
      fx:controller="org.aurora.launcher.ui.controller.settings.AboutController">
    
    <Label fx:id="versionLabel" styleClass="info-label"/>
    <Label fx:id="buildLabel" styleClass="info-label"/>
    
    <Hyperlink fx:id="githubLink" text="GitHub"/>
    <Hyperlink fx:id="websiteLink" text="%about.website"/>
    
    <TextArea fx:id="licenseArea" editable="false"/>
    
    <Button fx:id="checkUpdateButton" text="%update.check" onAction="#onCheckUpdate"/>
    <Button text="%settings.exportLogs" onAction="#onExportLogs"/>
    
</VBox>