<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.aurora.launcher.ui.component.input.MemorySlider?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="16" styleClass="dialog-content">
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="实例名称:" styleClass="form-label"/>
        <TextField fx:id="nameField" promptText="输入实例名称" HBox.hgrow="ALWAYS" styleClass="form-input"/>
    </HBox>
    
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Minecraft版本:" styleClass="form-label"/>
        <ComboBox fx:id="versionBox" promptText="选择版本" HBox.hgrow="ALWAYS" styleClass="form-combo"/>
    </HBox>
    
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="模组加载器:" styleClass="form-label"/>
        <ComboBox fx:id="loaderBox" promptText="选择加载器" styleClass="form-combo"/>
        <ComboBox fx:id="loaderVersionBox" promptText="选择版本" HBox.hgrow="ALWAYS" styleClass="form-combo" disable="true"/>
    </HBox>
    
    <VBox spacing="8">
        <Label text="内存设置:" styleClass="form-label"/>
        <MemorySlider fx:id="memorySlider"/>
    </VBox>
    
    <HBox spacing="8" alignment="CENTER_LEFT">
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="importButton" text="导入整合包" onAction="#onImport" styleClass="btn-secondary"/>
    </HBox>
</VBox>