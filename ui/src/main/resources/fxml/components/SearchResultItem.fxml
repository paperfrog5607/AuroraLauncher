<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml" styleClass="search-result-item" spacing="12">
    <ImageView fx:id="iconView" fitWidth="64" fitHeight="64" styleClass="result-icon"/>
    <VBox spacing="4" HBox.hgrow="ALWAYS">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="nameLabel" styleClass="result-name"/>
            <Label fx:id="authorLabel" styleClass="result-author"/>
        </HBox>
        <Label fx:id="descriptionLabel" styleClass="result-description" wrapText="true"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <HBox fx:id="tagsBox" spacing="4"/>
            <Label fx:id="downloadsLabel" styleClass="result-downloads"/>
        </HBox>
    </VBox>
    <HBox HBox.hgrow="ALWAYS"/>
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button fx:id="viewButton" text="查看" styleClass="btn-secondary, btn-sm"/>
        <Button fx:id="downloadButton" text="下载" styleClass="btn-primary, btn-sm"/>
    </HBox>
</HBox>