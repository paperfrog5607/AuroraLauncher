<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns:fx="http://javafx.com/fxml" styleClass="version-item" spacing="12">
    <VBox spacing="2" HBox.hgrow="ALWAYS">
        <Label fx:id="versionLabel" styleClass="version-id"/>
        <HBox spacing="8">
            <Label fx:id="typeLabel" styleClass="version-type"/>
            <Label fx:id="dateLabel" styleClass="version-date"/>
        </HBox>
    </VBox>
    <HBox HBox.hgrow="ALWAYS"/>
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button fx:id="downloadButton" text="下载" styleClass="btn-primary, btn-sm"/>
        <MenuButton fx:id="installButton" text="安装模组加载器" styleClass="btn-secondary, btn-sm"/>
    </HBox>
</HBox>