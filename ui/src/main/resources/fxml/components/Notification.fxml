<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml" styleClass="notification" spacing="10">
    <ImageView fx:id="iconView" fitWidth="24" fitHeight="24" styleClass="notification-icon"/>
    <Label fx:id="messageLabel" styleClass="notification-message" HBox.hgrow="ALWAYS"/>
    <HBox HBox.hgrow="ALWAYS"/>
    <Button fx:id="closeButton" text="×" styleClass="btn-icon, btn-close"/>
</HBox>